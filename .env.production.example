# Copy to .env.production on the Lightsail instance; do not commit the populated file.
DOMAIN=giftlist.example.com
DB_NAME=gogogiftlist
DB_USER=gogogiftlist
DB_PASSWORD=replace-with-a-long-random-database-password
DATABASE_URL=postgresql://gogogiftlist:replace-with-a-url-encoded-database-password@db:5432/gogogiftlist
DJANGO_SECRET_KEY=replace-with-a-long-random-django-secret-key
DJANGO_ALLOWED_HOSTS=giftlist.example.com
CSRF_TRUSTED_ORIGINS=https://giftlist.example.com
FRONTEND_URL=https://giftlist.example.com

# Amazon SES SMTP credentials. Verify DEFAULT_FROM_EMAIL in SES and move SES out of
# the sandbox before sending to unverified recipient addresses.
AWS_SES_REGION=us-east-1
AWS_SES_SMTP_USERNAME=replace-with-ses-smtp-username
AWS_SES_SMTP_PASSWORD=replace-with-ses-smtp-password
DEFAULT_FROM_EMAIL=GoGoGiftList <no-reply@giftlist.example.com>
